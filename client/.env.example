# Client env (Vite). Copy to client/.env. Only VITE_-prefixed vars reach the browser.
#
# The live portal fetches a join token from the token server, which also returns the
# LiveKit URL � so the browser only needs to know where the token server is.
#
# Local dev: leave VITE_TOKEN_URL unset (defaults to http://127.0.0.1:8788).
# Prod: set VITE_TOKEN_URL to the deployed token server, e.g. https://sam-token.onrender.com
VITE_TOKEN_URL=
