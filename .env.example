# S.A.M. — top-level env reference.
# Each package has its own .env.example; copy those into client/.env and worker/.env.
# This file documents the full set of variables in one place. NEVER commit real values.

# ── LiveKit (transport / SFU) ───────────────────────────────────────────────
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# ── STT: Deepgram Nova-3 ────────────────────────────────────────────────────
DEEPGRAM_API_KEY=

# ── TTS: ElevenLabs ─────────────────────────────────────────────────────────
ELEVENLABS_API_KEY=
# Persona voice ids (Samuel + sub-agents). Placeholders until selected/cloned.
SAM_VOICE_ID=
SCHEDULE_VOICE_ID=
DESIGN_VOICE_ID=
SALES_VOICE_ID=

# ── Brain: Hermes (OpenAI-compatible endpoint) ──────────────────────────────
HERMES_BASE_URL=
HERMES_API_KEY=

# ── Rainmaker command surface (rm_api) ──────────────────────────────────────
RM_API_BASE_URL=https://rainmaker-api-waqs.onrender.com
RM_API_TOKEN=

# ── Client (Vite, must be VITE_-prefixed to reach the browser) ──────────────
VITE_LIVEKIT_URL=wss://your-project.livekit.cloud
VITE_TOKEN_SERVER_URL=http://localhost:8788
VITE_USE_MOCK=1
