# Worker env. Copy to worker/.env. NEVER commit real values. --mock needs none of these.

# LiveKit (transport / SFU) - needed for the 5b transport phase + token server.
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# STT: LiveKit Inference by default (no key). For reliability when Inference rate-limits (429),
# add a free Deepgram key and set SAM_STT=deepgram.
DEEPGRAM_API_KEY=
SAM_STT=inference

# TTS: ElevenLabs (reuse the rm_api key). SAM_VOICE_ID = Samuel's signature voice.
ELEVENLABS_API_KEY=
ELEVENLABS_MODEL=eleven_flash_v2_5
SAM_VOICE_ID=
SCHEDULE_VOICE_ID=
DESIGN_VOICE_ID=
SALES_VOICE_ID=

# Brain for the POC: OpenAI gpt-4o-mini directly.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Groq (OpenAI-compatible, very low TTFT) - candidate live/low-tier brain for A/B.
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.1-8b-instant

# Hermes brain - OpenAI-compatible endpoint (this is "Charles"/ask_charles internally).
# Converge here later; leave blank for the POC.
HERMES_BASE_URL=
HERMES_API_KEY=

# Rainmaker command surface (read-only first)
RM_API_BASE_URL=https://rainmaker-api-waqs.onrender.com
RM_API_TOKEN=

# Barge-in / interruption sensitivity (higher = less twitchy).
# Sustained speech seconds AND recognized words required before Sam stops talking.
SAM_INTERRUPT_MIN_DURATION=0.8
SAM_INTERRUPT_MIN_WORDS=2

# Endpointing: silence (sec) before Sam decides you're done and replies.
# Lower = snappier but may cut you off mid-thought; raise if he jumps in early.
SAM_ENDPOINTING_MIN=0.3
SAM_ENDPOINTING_MAX=1.2

# Token server
TOKEN_SERVER_PORT=8788
